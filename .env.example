# API Keys
# API Keys
GEMINI_API_KEY=your_gemini_api_key_here
JWT_SECRET_KEY=change_this_to_a_long_random_string

# Database (defaults work with docker-compose)
DB_PASSWORD=changeme
DB_HOST=localhost
DB_USER=postgres
DB_NAME=aiversus
